#!/usr/bin/env build_python

# Wrapper for flang

import os
import sys
import shlex
from subprocess import Popen

args = sys.argv
del args[0]

new_args = [os.environ["_FORTRAN_EXECUTABLE"]]

if "-Wl,--version" in sys.argv or "--version" in sys.argv or "-Wl,-v" in sys.argv or "--help" in sys.argv or "-V" in sys.argv: # get linker from gfortran
    new_args.pop(0)
    new_args.insert(0, os.environ["_ORIGINAL_GFORTRAN_EXECUTABLE"])
    for arg in sys.argv:
        if new_args[-1] == "-target":
            new_args.pop(-1)
            continue
        new_args.append(arg)
else:
    clang = False
    if "-bundle" in sys.argv or "-dynamiclib" in sys.argv:
        # link with clang
        clang = True
        new_args.pop(0)
        new_args = ["iosxcrun", "--sdk", os.environ["SDK_NAME"], "clang"]+new_args
    elif "-c" not in sys.argv and "MacOSX.platform" not in " ".join(sys.argv):
        new_args.append("-c") # compile objects

    if clang:
        try:
            new_args = new_args+shlex.split(os.environ["LDFLAGS"])
        except KeyError:
            pass

    for arg in sys.argv:
        if arg == "-E" and not clang:
            new_args.append("-cpp")
        elif (arg == "-framework" or arg.startswith("-F") or new_args[-1] == "-framework") and not clang:
            new_args.append("-Xlinker")
        elif arg.startswith("-fvisibility=") or arg.startswith("-idirafter"):
            continue
        elif arg.startswith("-std="):
            arg = "-std=f2018"

        if new_args[-1] == "-arch": # -arch not supported by flang
            new_args.pop(-1)
            continue
        new_args.append(arg)

p = Popen(new_args)
p.wait()
sys.exit(p.returncode)

